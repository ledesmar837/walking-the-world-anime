# Variables de entorno — Copiar a .env.local y reemplazar con IDs reales

# ============================================
# 🔐 Google Search Console
# ============================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=iCMwVbrcJHfQ3dHXabGZBTi9jWt7LJHHsGjeO8YRpzg

# ============================================
# 📊 Google Analytics 4
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# 📦 Google Tag Manager
# ============================================
