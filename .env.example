# Slots (opcional, solo si quieres IDs específicos por ubicación)
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=

# ============================================
# 🔄 Revalidación
# ============================================
